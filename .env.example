# Browser-safe frontend configuration.
# Only publishable/public values may use the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Vercel API route configuration.
# Never expose these with a VITE_ prefix or import them in frontend code.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Before deploying: add aabnoor.shop as a verified sending domain in Resend dashboard.
# https://resend.com/domains
RESEND_API_KEY=
RESEND_FROM_DOMAIN=aabnoor.shop
ALLOWED_ORIGIN="https://aabnoor.shop,https://www.aabnoor.shop"
ORDER_EMAIL_FROM="Aabnoor <noreply@aabnoor.shop>"
AUTH_EMAIL_FROM="Aabnoor <noreply@aabnoor.shop>"
RESEND_FROM_EMAIL="Aabnoor <noreply@aabnoor.shop>"
ORDER_TRACKING_URL="https://aabnoor.shop/track"
SIGNUP_OTP_SECRET=
IP_HASH_SECRET=
REVIEW_HASH_SECRET=
ADMIN_EMAIL=
